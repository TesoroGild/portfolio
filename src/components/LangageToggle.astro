---
// On récupère l'URL actuelle pour savoir où on est
const { pathname } = Astro.url;

// On calcule l'URL inverse
// Si on est sur /en/contact -> on veut /fr/contact (et inversement)
const isEn = pathname.startsWith('/en');
const redirectPath = isEn 
  ? pathname.replace('/en', '/fr') || '/fr/' 
  : pathname.replace('/fr', '/en') || '/en/';
---

<a href={redirectPath} class="lang-link">
  {isEn ? 'FR' : 'EN'}
</a>

<style>
  .lang-link {
    cursor: pointer;
    padding: 0.5rem;
    border: 1px solid currentColor;
    border-radius: 4px;
    text-decoration: none;
  }
</style>
